[sub_resource type="GDScript" id="GDScript_5fd42"]
script/source = "extends CharacterBody2D

var direction := -1
var dead := false

@onready var wall_detector := $wall_detector as RayCast2D
@onready var texture := $texture as Sprite2D
@onready var anim := $anim

const SPEED = 70.0

func _ready():
	add_to_group(\"enemies\")

func _physics_process(delta):

	# inimigo morto
	if dead:
		velocity += get_gravity() * delta
		move_and_slide()
		return

	# gravidade
	if not is_on_floor():
		velocity += get_gravity() * delta

	# virar ao detectar parede
	if wall_detector.is_colliding():
		direction *= -1
		
		texture.flip_h = !texture.flip_h
		
		wall_detector.target_position.x *= -1

	# movimento
	velocity.x = direction * SPEED

	move_and_slide()

func die():

	dead = true

	# adiciona 100 pontos
	Globals.score += 100

	# para movimento horizontal
	velocity.x = 0

	# joga pra cima
	velocity.y = -200

	# vira corpo
	rotation_degrees = 180

	anim.play(\"hurt\")

	# remove rápido
	await get_tree().create_timer(0.5).timeout

	queue_free()
	# remove rápido
	await get_tree().create_timer(0.5).timeout
	
	queue_free()
"

